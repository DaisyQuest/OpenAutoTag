{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/layout.schema.json",
  "title": "LayoutDocument",
  "type": "object",
  "required": [
    "schemaVersion",
    "documentId",
    "source",
    "pages"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "documentId": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "required": [
        "filePath"
      ],
      "properties": {
        "filePath": {
          "type": "string",
          "minLength": 1
        },
        "pageCount": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "pageNumber",
          "width",
          "height",
          "textBlocks"
        ],
        "properties": {
          "pageNumber": {
            "type": "integer",
            "minimum": 1
          },
          "width": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "height": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "columns": {
            "type": "integer",
            "minimum": 1
          },
          "textBlocks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "text",
                "bbox",
                "fontSize"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "text": {
                  "type": "string"
                },
                "bbox": {
                  "type": "array",
                  "minItems": 4,
                  "maxItems": 4,
                  "prefixItems": [
                    {
                      "type": "number"
                    },
                    {
                      "type": "number"
                    },
                    {
                      "type": "number",
                      "minimum": 0
                    },
                    {
                      "type": "number",
                      "minimum": 0
                    }
                  ],
                  "items": false
                },
                "fontSize": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "fontName": {
                  "type": "string"
                },
                "blockType": {
                  "type": "string",
                  "enum": [
                    "heading",
                    "paragraph",
                    "list-item",
                    "table-cell",
                    "unknown"
                  ]
                },
                "headingLevel": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 6
                },
                "columnHint": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

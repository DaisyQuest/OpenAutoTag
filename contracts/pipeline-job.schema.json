{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/pipeline-job.schema.json",
  "title": "PipelineJob",
  "type": "object",
  "required": [
    "jobId",
    "status",
    "workload",
    "input",
    "artifacts",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "jobId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "completed",
        "failed"
      ]
    },
    "workload": {
      "type": "object",
      "required": [
        "id",
        "label"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "shortLabel": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "primaryArtifact": {
          "type": "string"
        },
        "previewArtifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "downloadArtifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "input": {
      "type": "object",
      "required": [
        "filePath"
      ],
      "properties": {
        "filePath": {
          "type": "string",
          "minLength": 1
        },
        "outputDir": {
          "type": "string"
        },
        "workloadId": {
          "type": "string"
        },
        "options": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "layout": {
          "type": "string"
        },
        "sourceTextMap": {
          "type": "string"
        },
        "layoutEnriched": {
          "type": "string"
        },
        "tableStructureMap": {
          "type": "string"
        },
        "semantic": {
          "type": "string"
        },
        "semanticRedacted": {
          "type": "string"
        },
        "semanticOrdered": {
          "type": "string"
        },
        "tagging": {
          "type": "string"
        },
        "redactionPlan": {
          "type": "string"
        },
        "taggedPdf": {
          "type": "string"
        },
        "tagManifest": {
          "type": "string"
        },
        "writerReport": {
          "type": "string"
        },
        "validationReport": {
          "type": "string"
        },
        "redactedPdf": {
          "type": "string"
        },
        "redactionReport": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "createdAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
    },
    "updatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
    },
    "error": {
      "type": "string"
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/semantic.schema.json",
  "title": "SemanticDocument",
  "type": "object",
  "required": [
    "schemaVersion",
    "documentId",
    "source",
    "nodes"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "documentId": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "required": [
        "layoutDocumentId"
      ],
      "properties": {
        "layoutDocumentId": {
          "type": "string",
          "minLength": 1
        },
        "filePath": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "pageNumber",
          "sourceBlockId",
          "role",
          "text",
          "bbox",
          "confidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "pageNumber": {
            "type": "integer",
            "minimum": 1
          },
          "sourceBlockId": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": [
              "Document",
              "H1",
              "H2",
              "H3",
              "P",
              "L",
              "LI",
              "Table",
              "TH",
              "TD",
              "Artifact"
            ]
          },
          "text": {
            "type": "string"
          },
          "bbox": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "prefixItems": [
              {
                "type": "number"
              },
              {
                "type": "number"
              },
              {
                "type": "number",
                "minimum": 0
              },
              {
                "type": "number",
                "minimum": 0
              }
            ],
            "items": false
          },
          "headingLevel": {
            "type": "integer",
            "minimum": 1,
            "maximum": 6
          },
          "columnHint": {
            "type": "integer",
            "minimum": 0
          },
          "readingOrder": {
            "type": "integer",
            "minimum": 0
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "additionalProperties": true
      }
    },
    "orderedNodeIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/tagging.schema.json",
  "title": "TaggingDocument",
  "type": "object",
  "required": [
    "schemaVersion",
    "documentId",
    "source",
    "root"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "documentId": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "required": [
        "semanticDocumentId"
      ],
      "properties": {
        "semanticDocumentId": {
          "type": "string",
          "minLength": 1
        },
        "filePath": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "root": {
      "$ref": "#/$defs/tagNode"
    },
    "fontInventoryRef": {
      "type": "string",
      "description": "Optional path (relative to job workspace) to a font-inventory.schema.json document produced by the font-embedder stage. When present, pdf-writer MUST honor its plan[] entries."
    }
  },
  "$defs": {
    "tagNode": {
      "type": "object",
      "required": [
        "id",
        "type",
        "children"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "Document",
            "Sect",
            "Title",
            "H1",
            "H2",
            "H3",
            "H4",
            "H5",
            "H6",
            "P",
            "L",
            "LI",
            "Lbl",
            "LBody",
            "Caption",
            "Figure",
            "Aside",
            "BlockQuote",
            "Span",
            "Form",
            "Table",
            "THead",
            "TBody",
            "TFoot",
            "TR",
            "TH",
            "TD"
          ]
        },
        "label": {
          "type": "string"
        },
        "sourceNodeIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tagNode"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

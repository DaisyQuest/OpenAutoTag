{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/machine-learning/contracts-draft/ml-predictions.schema.json",
  "title": "MlPredictionsDocumentDraft",
  "type": "object",
  "required": [
    "schemaVersion",
    "documentId",
    "source",
    "model",
    "runtimePolicy",
    "documentProfile",
    "predictions",
    "calibration",
    "shadowMode"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.1.0-draft"
    },
    "documentId": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "required": [
        "layoutDocumentId"
      ],
      "properties": {
        "layoutDocumentId": {
          "type": "string",
          "minLength": 1
        },
        "semanticDocumentId": {
          "type": "string"
        },
        "filePath": {
          "type": "string"
        },
        "inputSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": true
    },
    "model": {
      "type": "object",
      "required": [
        "id",
        "version",
        "taskHeads",
        "trainingDatasetVersion"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "taskHeads": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "role-classification",
              "object-detection",
              "relationship-prediction",
              "table-structure",
              "reading-order-ranking",
              "tag-tree-validation",
              "ood-detection"
            ]
          }
        },
        "trainingDatasetVersion": {
          "type": "string",
          "minLength": 1
        },
        "modelCardPath": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "runtimePolicy": {
      "type": "object",
      "required": [
        "mode",
        "fallbackBehavior",
        "abstentionEnabled"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "shadow",
            "assistive",
            "disabled"
          ]
        },
        "fallbackBehavior": {
          "type": "string",
          "enum": [
            "deterministic-only",
            "deterministic-on-low-confidence",
            "deterministic-on-ood",
            "deterministic-on-any-policy-fail"
          ]
        },
        "abstentionEnabled": {
          "type": "boolean"
        },
        "emergencyDisableFlag": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "documentProfile": {
      "type": "object",
      "required": [
        "oodScore",
        "oodDecision"
      ],
      "properties": {
        "oodScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "oodDecision": {
          "type": "string",
          "enum": [
            "in-distribution",
            "near-boundary",
            "out-of-distribution",
            "unknown"
          ]
        },
        "matchedProfiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "producerProfile": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "predictions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "taskHead",
          "target",
          "prediction",
          "confidence",
          "calibratedConfidence",
          "abstention",
          "contractProjection"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "taskHead": {
            "type": "string",
            "enum": [
              "role-classification",
              "object-detection",
              "relationship-prediction",
              "table-structure",
              "reading-order-ranking",
              "tag-tree-validation",
              "ood-detection"
            ]
          },
          "target": {
            "type": "object",
            "required": [
              "pageNumber"
            ],
            "properties": {
              "sourceBlockId": {
                "type": "string"
              },
              "sourceNodeId": {
                "type": "string"
              },
              "pageNumber": {
                "type": "integer",
                "minimum": 1
              },
              "bbox": {
                "$ref": "#/$defs/bbox"
              },
              "relatedTargetIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          },
          "prediction": {
            "type": "object",
            "required": [
              "label"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "alternatives": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "label",
                    "confidence"
                  ],
                  "properties": {
                    "label": {
                      "type": "string"
                    },
                    "confidence": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    }
                  },
                  "additionalProperties": true
                }
              }
            },
            "additionalProperties": true
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "calibratedConfidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "abstention": {
            "type": "object",
            "required": [
              "abstained",
              "reason"
            ],
            "properties": {
              "abstained": {
                "type": "boolean"
              },
              "reason": {
                "type": "string",
                "enum": [
                  "none",
                  "low-confidence",
                  "ood",
                  "contract-gap",
                  "ambiguous-input",
                  "missing-required-features",
                  "runtime-policy"
                ]
              },
              "threshold": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            },
            "additionalProperties": true
          },
          "contractProjection": {
            "type": "object",
            "required": [
              "status"
            ],
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "semantic-compatible",
                  "tagging-compatible",
                  "table-compatible",
                  "contract-gap",
                  "research-only"
                ]
              },
              "targetContract": {
                "type": "string"
              },
              "targetField": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "evidence": {
            "type": "object",
            "properties": {
              "featureSummary": {
                "type": "object",
                "additionalProperties": true
              },
              "nearestTrainingProfiles": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "explanation": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "calibration": {
      "type": "object",
      "required": [
        "datasetVersion",
        "globalExpectedCalibrationError",
        "sliceStatus"
      ],
      "properties": {
        "datasetVersion": {
          "type": "string",
          "minLength": 1
        },
        "globalExpectedCalibrationError": {
          "type": "number",
          "minimum": 0
        },
        "globalBrierScore": {
          "type": "number",
          "minimum": 0
        },
        "sliceStatus": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "slice",
              "status"
            ],
            "properties": {
              "slice": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "pass",
                  "warn",
                  "fail",
                  "not-measured"
                ]
              },
              "expectedCalibrationError": {
                "type": "number",
                "minimum": 0
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "shadowMode": {
      "type": "object",
      "required": [
        "enabled",
        "wouldChangeOutput",
        "decisionLogs"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "wouldChangeOutput": {
          "type": "boolean"
        },
        "decisionLogs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "targetId",
              "deterministicDecision",
              "mlDecision",
              "finalDecision",
              "fallbackReason"
            ],
            "properties": {
              "targetId": {
                "type": "string"
              },
              "deterministicDecision": {
                "type": "string"
              },
              "mlDecision": {
                "type": "string"
              },
              "finalDecision": {
                "type": "string"
              },
              "fallbackReason": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "bbox": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "prefixItems": [
        {
          "type": "number"
        },
        {
          "type": "number"
        },
        {
          "type": "number",
          "minimum": 0
        },
        {
          "type": "number",
          "minimum": 0
        }
      ],
      "items": false
    }
  },
  "additionalProperties": true
}

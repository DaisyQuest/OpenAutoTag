{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/machine-learning/contracts-draft/ml-ground-truth.schema.json",
  "title": "MlGroundTruthDocumentDraft",
  "type": "object",
  "required": [
    "schemaVersion",
    "caseId",
    "corpus",
    "source",
    "split",
    "lineage",
    "hashes",
    "labels",
    "leakageFingerprints",
    "verification"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.1.0-draft"
    },
    "caseId": {
      "type": "string",
      "minLength": 1
    },
    "corpus": {
      "type": "object",
      "required": [
        "name",
        "version",
        "wave"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "wave": {
          "type": "string",
          "enum": [
            "wave-1",
            "wave-2",
            "real-anchor",
            "real-derived"
          ]
        },
        "shardId": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "source": {
      "type": "object",
      "required": [
        "pdfPath",
        "pageCount",
        "origin"
      ],
      "properties": {
        "pdfPath": {
          "type": "string",
          "minLength": 1
        },
        "pageCount": {
          "type": "integer",
          "minimum": 1
        },
        "origin": {
          "type": "string",
          "enum": [
            "synthetic",
            "transformed-synthetic",
            "real-public",
            "real-private-redacted",
            "transformed-real-public",
            "transformed-real-private-redacted"
          ]
        },
        "license": {
          "type": "string"
        },
        "provenance": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "split": {
      "type": "object",
      "required": [
        "name",
        "selectionUnitId",
        "locked"
      ],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "train",
            "validation",
            "test",
            "locked-audit"
          ]
        },
        "selectionUnitId": {
          "type": "string",
          "minLength": 1,
          "description": "Cluster or parent identifier used to prevent near-duplicate split leakage."
        },
        "locked": {
          "type": "boolean"
        },
        "holdoutReasons": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "template-holdout",
              "transform-holdout",
              "producer-holdout",
              "text-source-holdout",
              "real-anchor-holdout",
              "human-audit-holdout"
            ]
          }
        }
      },
      "additionalProperties": true
    },
    "lineage": {
      "type": "object",
      "required": [
        "parentCaseIds"
      ],
      "properties": {
        "parentCaseIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "transform": {
          "type": "object",
          "required": [
            "id",
            "version",
            "oracleType",
            "oracleConfidence"
          ],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            },
            "oracleType": {
              "type": "string",
              "enum": [
                "preserving",
                "monotonic",
                "threshold",
                "counterfactual",
                "extraction",
                "real-anchor-label"
              ]
            },
            "oracleConfidence": {
              "$ref": "#/$defs/confidenceTier"
            },
            "parameters": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "hashes": {
      "type": "object",
      "required": [
        "pdfSha256",
        "truthSha256"
      ],
      "properties": {
        "pdfSha256": {
          "$ref": "#/$defs/sha256"
        },
        "truthSha256": {
          "$ref": "#/$defs/sha256"
        },
        "renderSha256": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sha256"
          }
        },
        "sourceTextSha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": true
    },
    "labels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "role",
          "pageNumber",
          "confidenceTier",
          "contractProjection",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "region",
              "block",
              "token",
              "relationship",
              "table",
              "table-cell",
              "tag-tree-node",
              "artifact"
            ]
          },
          "role": {
            "$ref": "#/$defs/mlRole"
          },
          "pageNumber": {
            "type": "integer",
            "minimum": 1
          },
          "bbox": {
            "$ref": "#/$defs/bbox"
          },
          "text": {
            "type": "string"
          },
          "confidenceTier": {
            "$ref": "#/$defs/confidenceTier"
          },
          "contractProjection": {
            "type": "object",
            "required": [
              "status"
            ],
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "layout-compatible",
                  "semantic-compatible",
                  "tagging-compatible",
                  "table-compatible",
                  "contract-gap",
                  "research-only"
                ]
              },
              "targetContract": {
                "type": "string"
              },
              "targetRole": {
                "type": "string"
              },
              "notes": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "evidence": {
            "type": "object",
            "required": [
              "constructed",
              "renderVerified",
              "extractionVerified",
              "humanVerified"
            ],
            "properties": {
              "constructed": {
                "type": "boolean"
              },
              "renderVerified": {
                "type": "boolean"
              },
              "extractionVerified": {
                "type": "boolean"
              },
              "engineProjected": {
                "type": "boolean"
              },
              "humanVerified": {
                "type": "boolean"
              },
              "vividEvidenceBlockIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "fromLabelId",
          "toLabelId",
          "confidenceTier"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "parent-child",
              "reading-order-before",
              "footnote-reference",
              "endnote-reference",
              "caption-of",
              "header-for",
              "table-cell-in",
              "list-label-for",
              "artifact-overlaps"
            ]
          },
          "fromLabelId": {
            "type": "string",
            "minLength": 1
          },
          "toLabelId": {
            "type": "string",
            "minLength": 1
          },
          "confidenceTier": {
            "$ref": "#/$defs/confidenceTier"
          }
        },
        "additionalProperties": true
      }
    },
    "leakageFingerprints": {
      "type": "object",
      "required": [
        "templateHash",
        "textSourceHash",
        "assetHashes",
        "producerProfileHash"
      ],
      "properties": {
        "templateHash": {
          "type": "string",
          "minLength": 1
        },
        "textSourceHash": {
          "type": "string",
          "minLength": 1
        },
        "tableSchemaHashes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "assetHashes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "producerProfileHash": {
          "type": "string",
          "minLength": 1
        },
        "renderPerceptualHashes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "verification": {
      "type": "object",
      "required": [
        "status",
        "labelConfidenceSummary",
        "humanAudit"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "accepted",
            "quarantined",
            "rejected",
            "ambiguous"
          ]
        },
        "labelConfidenceSummary": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "humanAudit": {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "not-sampled",
                "queued",
                "passed",
                "failed-label-bug",
                "failed-generator-bug",
                "ambiguous",
                "contract-gap"
              ]
            },
            "reviewerCount": {
              "type": "integer",
              "minimum": 0
            },
            "agreement": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "bbox": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "prefixItems": [
        {
          "type": "number"
        },
        {
          "type": "number"
        },
        {
          "type": "number",
          "minimum": 0
        },
        {
          "type": "number",
          "minimum": 0
        }
      ],
      "items": false
    },
    "confidenceTier": {
      "type": "string",
      "enum": [
        "constructed",
        "render-verified",
        "extraction-verified",
        "engine-projected",
        "human-verified",
        "ambiguous",
        "contract-gap"
      ]
    },
    "mlRole": {
      "type": "string",
      "enum": [
        "Document",
        "H1",
        "H2",
        "H3",
        "H4",
        "H5",
        "H6",
        "P",
        "L",
        "LI",
        "Lbl",
        "LBody",
        "Table",
        "THead",
        "TBody",
        "TFoot",
        "TR",
        "TH",
        "TD",
        "Caption",
        "Figure",
        "Form",
        "Aside",
        "BlockQuote",
        "FootnoteReference",
        "FootnoteBody",
        "EndnoteReference",
        "EndnoteBody",
        "Artifact",
        "Unknown",
        "Ambiguous"
      ]
    }
  },
  "additionalProperties": true
}
